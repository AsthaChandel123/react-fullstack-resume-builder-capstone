rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Criteria: employer reads own (any status), others read active only, authenticated create
    match /criteria/{code} {
      allow read: if resource.data.employerId == request.auth.uid
        || resource.data.status == 'active';
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.employerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.employerId == request.auth.uid;
    }

    // Sessions: only the owning candidate
    match /sessions/{sessionId} {
      allow read, update: if request.auth != null
        && resource.data.candidateId == request.auth.uid;
      allow create: if false; // Cloud Functions only
      allow delete: if false;
    }

    // Scorecards: candidates own, employers for their criteria, only Cloud Functions create
    match /scorecards/{scorecardId} {
      allow read: if request.auth != null
        && (resource.data.candidateId == request.auth.uid
            || resource.data.employerId == request.auth.uid);
      allow create, update, delete: if false; // Cloud Functions only
    }

    // Matches: candidates create, both sides read
    match /matches/{matchId} {
      allow read: if request.auth != null
        && (resource.data.candidateId == request.auth.uid
            || resource.data.employerId == request.auth.uid);
      allow create: if false; // Cloud Functions only
      allow update, delete: if false;
    }

    // Replies: employers create, both sides read
    match /replies/{replyId} {
      allow read: if request.auth != null
        && (resource.data.candidateId == request.auth.uid
            || resource.data.employerId == request.auth.uid);
      allow create, update, delete: if false; // Cloud Functions only
    }

    // Notifications: only the recipient reads, Cloud Functions write
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && resource.data.recipientId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Devices: only the owner can read/write their own device doc
    match /devices/{deviceId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Email-device binding: only the owner can read/write their own binding
    match /emailDevices/{emailHash} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Mail collection for SendGrid trigger
    match /mail/{mailId} {
      allow read, write: if false; // Cloud Functions only
    }

    // Public, slug-addressable, openly editable resume snapshots.
    // Anyone with the URL can read AND edit. Slug must be 6-32 chars to
    // make brute-force enumeration impractical. Only the `resume` and
    // timestamp fields are accepted. No deletes.
    match /resumes/{slug} {
      function validSlug() {
        return slug.size() >= 6 && slug.size() <= 32
          && slug.matches('[A-Za-z0-9_-]+');
      }
      function validPayload() {
        return request.resource.data.keys().hasOnly(['resume', 'createdAt', 'updatedAt'])
          && request.resource.data.resume is map;
      }
      allow read: if validSlug();
      allow create: if validSlug() && validPayload();
      allow update: if validSlug() && validPayload();
      allow delete: if false;
    }
  }
}
